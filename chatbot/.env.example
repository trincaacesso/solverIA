# Copy to .env and fill in. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default model for all clients (each client JSON can override with "model").
# Options: claude-opus-4-8 (most capable) | claude-sonnet-5 | claude-haiku-4-5 (cheapest)
# MODEL=claude-opus-4-8

# Optional: port (Render/host sets PORT automatically)
# PORT=8787
